<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.owl-ontologies.com/family_lab.owl#"
     xml:base="http://www.owl-ontologies.com/family_lab.owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:family_lab="http://www.owl-ontologies.com/family_lab.owl#">
    <owl:Ontology rdf:about="http://www.owl-ontologies.com/family_lab.owl"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isBrotherOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isBrotherOf">
        <rdfs:subPropertyOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isSiblingOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isChildOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isChildOf">
        <owl:inverseOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isDaughterOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isDaughterOf">
        <rdfs:subPropertyOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isChildOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isFatherOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isFatherOf">
        <rdfs:subPropertyOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isMarriedWith -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isMarriedWith">
        <owl:inverseOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isMarriedWith"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isMotherOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isMotherOf">
        <rdfs:subPropertyOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isParentOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isParentOf">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isSiblingOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isSiblingOf">
        <owl:inverseOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isSiblingOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isSisterOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isSisterOf">
        <rdfs:subPropertyOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isSiblingOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#isSonOf -->

    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#isSonOf">
        <rdfs:subPropertyOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isChildOf"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.owl-ontologies.com/family_lab.owl#age -->

    <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#age">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#name -->

    <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#name">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#nationality -->

    <owl:DatatypeProperty rdf:about="http://www.owl-ontologies.com/family_lab.owl#nationality">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Brother -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Brother">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isBrotherOf"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sibling"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Daughter"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandmother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Mother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sister"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Child -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Child">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Daughter -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Daughter">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isDaughterOf"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Child"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Father"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandfather"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Son"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Uncle"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Father -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Father">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.owl-ontologies.com/family_lab.owl#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                        <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Parent"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandmother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Mother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sister"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Female -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Female">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandfather"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Son"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Uncle"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Grandfather -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Grandfather">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.owl-ontologies.com/family_lab.owl#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                                <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Father"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandparents"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandmother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Mother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sister"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Grandmother -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Grandmother">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.owl-ontologies.com/family_lab.owl#Female"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                                <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Grandparents"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Mother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Son"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Uncle"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Grandparents -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Grandparents">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                        <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Parent"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Male -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Male">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Mother"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sister"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Mother -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Mother">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.owl-ontologies.com/family_lab.owl#Female"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                        <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Parent"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Son"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Uncle"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Parent -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Parent">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Person -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Sibling -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Sibling">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Sister -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Sister">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isSisterOf"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sibling"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Son"/>
        <owl:disjointWith rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Uncle"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Son -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Son">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isSonOf"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Child"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Uncle -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/family_lab.owl#Uncle">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isBrotherOf"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.owl-ontologies.com/family_lab.owl#isParentOf"/>
                        <owl:someValuesFrom rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Brother"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Male"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Chloe -->

    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/family_lab.owl#Chloe">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Child"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Daughter"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <isChildOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Marie"/>
        <isChildOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Peter"/>
        <isDaughterOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Marie"/>
        <isDaughterOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Peter"/>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</age>
        <name>Chloe</name>
    </owl:NamedIndividual>
    


    <!-- http://www.owl-ontologies.com/family_lab.owl#Claude -->

    <owl:NamedIndividual rdf:about="http://www.owl-ontologies.com/family_lab.owl#Claude">
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Child"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Daughter"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Female"/>
        <rdf:type rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Person"/>
        <isChildOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sylvie"/>
        <isDaughterOf rdf:resource="http://www.owl-ontologies.com/family_lab.owl#Sylvie"/>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</age>
        <name>Claude</name>
        <nationality>French</nationality>
    </owl:NamedIndividual>
    


