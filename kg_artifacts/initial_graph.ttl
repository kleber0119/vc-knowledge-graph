# ── Sectors ───────────────────────────────────────────────────────────────────

vckg:Biotech a vckg:Sector ;
    rdfs:label "biotech"@en .

vckg:Fintech a vckg:Sector ;
    rdfs:label "fintech"@en .

# ── Funding Rounds ────────────────────────────────────────────────────────────

vckg:SeedRound a vckg:FundingRound ;
    rdfs:label "seed round"@en .

vckg:SeriesA a vckg:FundingRound ;
    rdfs:label "Series A"@en .

vckg:SeriesB a vckg:FundingRound ;
    rdfs:label "Series B"@en .

vckg:SeriesC a vckg:FundingRound ;
    rdfs:label "Series C"@en .

vckg:SeriesD a vckg:FundingRound ;
    rdfs:label "Series D"@en .

# ── Exit Events ───────────────────────────────────────────────────────────────

vckg:Acquisition a vckg:ExitEvent ;
    rdfs:label "acquisition"@en .

vckg:IPO a vckg:ExitEvent ;
    rdfs:label "IPO"@en,
        "initial public offering"@en .
