    rdfs:label "Leo Strauss"@en .

vckg:MarcAndreessen a vckg:Person ;
    rdfs:label "Marc Andreessen"@en ;
    vckg:partnerAt vckg:AndreessenHorowitz .

vckg:MarkZuckerberg a vckg:Person ;
    rdfs:label "Mark Zuckerberg"@en .

vckg:MattDanzeisen a vckg:Person ;
    rdfs:label "Matt Danzeisen"@en .

vckg:OwenThoma a vckg:Person ;
    rdfs:label "Owen Thomas"@en .

vckg:PaulGraham a vckg:Person ;
    rdfs:label "Paul Graham"@en .

